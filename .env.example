# set to "mock" to use the bundled test emails, "gmail" to connect to a real inbox
EMAIL_SOURCE=mock

# only used when EMAIL_SOURCE=mock, docker-compose overrides this path
MOCK_DATA_PATH=/data/mock/emails.json

# Gmail IMAP settings (only needed when EMAIL_SOURCE=gmail)
# for the password: go to myaccount.google.com/apppasswords and generate a 16-char app password
# use that here, NOT your actual Gmail password
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-email@gmail.com
IMAP_PASSWORD=your-16-char-app-password
IMAP_MAILBOX=INBOX
IMAP_FETCH_LIMIT=25

# how often to check for new emails (in seconds)
POLL_INTERVAL_SECONDS=120
